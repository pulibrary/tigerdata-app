{
  "name": "tiger-data-app",
  "packageManager": "yarn@4.16.0",
  "browserslist": [
    "defaults"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.27.0",
    "eslint": "^8.33.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^21.1.0",
    "lint-staged": "^16.2.7",
    "nanoid": ">=3.3.8",
    "precommit-hook": "^3.0.0",
    "prettier": "3.4.2",
    "rollup": "^4.59.0",
    "vite": "^7.3.5",
    "vite-plugin-ruby": "^5.2.2",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.6",
    "@rails/actioncable": "^7.1.3",
    "@rollup/plugin-inject": "^5.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vueuse/core": "^14.2.1",
    "bootstrap": "^5.2.3",
    "brace-expansion": "^5.0.7",
    "browserslist": "^4.21.5",
    "datatables": "^1.10.18",
    "datatables.net-dt": "^2.3.7",
    "datatables.net-vue3": "^3.0.4",
    "glob": "13.0.6",
    "jquery": "^3.6.3",
    "lodash": "^4.18",
    "lux-design-system": "^7.7.2",
    "minimatch": "10.2.3",
    "nanoid": ">=3.3.8",
    "vite-plugin-rails": "^0.5.0",
    "vue": "^3.5.22"
  },
  "scripts": {
    "lint": "eslint 'app/javascript/**/*.js'",
    "lint-staged": "lint-staged",
    "test": "vitest run --coverage",
    "test:dev": "vitest",
    "validate": "npm ls",
    "validate-license": "bundle exec rake dev_license:expiration_check"
  },
  "lint-staged": {
    "app/*rb": "bundle exec rubocop -a",
    "config/*rb": "bundle exec rubocop -a",
    "lib/*rb": "bundle exec rubocop -a",
    "lib/*rake": "bundle exec rubocop -a",
    "spec/*rb": "bundle exec rubocop -a",
    "*.js": "eslint --fix",
    "*.md": "prettier --write",
    "*css": "prettier --write",
    "*js": "prettier --write",
    "*.yml": "prettier --write"
  },
  "pre-commit": [
    "lint",
    "validate",
    "test"
  ]
}
