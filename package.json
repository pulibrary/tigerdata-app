{
  "name": "tiger-data-app",
  "packageManager": "yarn@4.3.1",
  "browserslist": [
    "defaults"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "nanoid": ">=5.1.9",
    "precommit-hook": "^3.0.0",
    "prettier": "3.8.3",
    "rollup": "^4.60.1",
    "vite": "^8.0.0",
    "vite-plugin-ruby": "^5.2.0",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@rails/actioncable": "^8.1.300",
    "@rollup/plugin-inject": "^5.0.5",
    "@vitejs/plugin-vue": "^6.0.6",
    "bootstrap": "^5.3.8",
    "brace-expansion": "^5.0.5",
    "browserslist": "^4.28.2",
    "datatables": "^1.10.18",
    "datatables.net-dt": "^2.3.7",
    "datatables.net-vue3": "^3.0.6",
    "glob": "13.0.6",
    "jquery": "^4.0.0",
    "lux-design-system": "^7.5.0",
    "minimatch": "10.2.5",
    "nanoid": ">=5.1.9",
    "vite-plugin-rails": "^0.6.0",
    "vue": "^3.5.32",
    "yarn": "^1.22.22",
    "yarn.lock": "^0.0.1-security"
  },
  "scripts": {
    "lint": "eslint 'app/javascript/**/*.js'",
    "lint-staged": "lint-staged",
    "test": "vitest run --coverage",
    "test:dev": "vitest",
    "validate": "npm ls",
    "validate-license": "bundle exec rake dev_license:expiration_check"
  },
  "pre-commit": [
    "validate-license",
    "lint-staged"
  ],
  "lint-staged": {
    "app/*rb": "bundle exec rubocop -a",
    "config/*rb": "bundle exec rubocop -a",
    "lib/*rb": "bundle exec rubocop -a",
    "lib/*rake": "bundle exec rubocop -a",
    "spec/*rb": "bundle exec rubocop -a",
    "*.js": "eslint --fix",
    "*.md": "prettier --write",
    "*css": "prettier --write",
    "*js": "prettier --write",
    "*.yml": "prettier --write"
  }
}
